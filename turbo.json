{
  "$schema": "https://turbo.build/schema.json",
  "globalDependencies": ["**/.env.*local", "**/.env"],
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "outputs": [".next/**", "!.next/cache/**", "dist/**"],
      "env": [
        "NODE_ENV",
        "NEXT_PUBLIC_*",
        "CLERK_*",
        "DATABASE_URL",
        "AWS_KMS_KEY_ID",
        "AWS_REGION",
        "PADDLE_*",
        "RESEND_API_KEY",
        "AI_GATEWAY_API_KEY",
        "SENTRY_*",
        "AXIOM_*"
      ]
    },
    "dev": {
      "cache": false,
      "persistent": true
    },
    "lint": {},
    "typecheck": {
      "dependsOn": ["^build"]
    },
    "clean": {
      "cache": false
    }
  }
}
