# Database (Neon Postgres)
DATABASE_URL=postgres://user:pass@host/db?sslmode=require

# Clerk (auto-provisioned by Vercel Marketplace in prod)
CLERK_SECRET_KEY=
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up

# AWS KMS (envelope encryption for stored API keys)
AWS_REGION=us-east-1
AWS_KMS_KEY_ID=
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=

# Vercel AI Gateway
AI_GATEWAY_API_KEY=

# Paddle (billing — Merchant of Record)
PADDLE_API_KEY=
PADDLE_WEBHOOK_SECRET=
PADDLE_PRO_PRICE_ID=

# Resend (transactional email)
RESEND_API_KEY=
RESEND_FROM_ADDRESS=support@1scratch.ai

# Observability
SENTRY_DSN=
AXIOM_TOKEN=
AXIOM_DATASET=
